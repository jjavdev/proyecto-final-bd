// Esquema de base de datos de Decarrerita.
// Define 12 tablas para la gestion de usuarios, choferes, clientes, vehiculos, traslados y pagos.
// Usa PostgreSQL con el cliente Prisma ORM.

generator client {
  provider = "prisma-client-js"
}

// Genera el diagrama E-R en docs/ERD.md automaticamente
generator erd {
  provider = "prisma-erd-generator"
  output   = "../docs/ERD.md"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles de usuario del sistema
enum Rol {
  ADMIN
  CHOFER
  CLIENTE
  PERSONAL_ADMIN
}

// Tabla base de usuarios. Cada usuario tiene un rol y datos personales basicos.
// Se relaciona 1:1 con choferes, clientes o personal_admin segun el rol.
model Usuario {
  @@map("usuarios")
  id             Int       @id @default(autoincrement())
  email          String    @unique
  password_hash  String
  nombre         String
  apellido       String
  cedula         String    @unique
  telefono       String
  rol            Rol
  activo         Boolean   @default(true)
  creado_en      DateTime  @default(now())
  actualizado_en DateTime  @updatedAt

  chofer          Chofer?
  cliente         Cliente?
  personal_admin  PersonalAdmin?
}

// Datos especificos del chofer: banco, cuentas y saldos.
// activo=false hasta que apruebe la evaluacion psicologica (nota >= 73).
// saldo_pendiente: monto acumulado por viajes realizados no pagados.
// saldo_pagado: monto ya cancelado por el personal administrativo.
model Chofer {
  @@map("choferes")
  id                Int      @id @default(autoincrement())
  usuario_id        Int      @unique
  banco_id          Int
  nro_cuenta        String
  saldo_pendiente   Float    @default(0)
  saldo_pagado      Float    @default(0)
  activo            Boolean  @default(true)
  creado_en         DateTime @default(now())

  usuario               Usuario              @relation(fields: [usuario_id], references: [id])
  banco                 Banco                @relation(fields: [banco_id], references: [id])
  vehiculos             Vehiculo[]
  contactos_emergencia  ContactoEmergencia[]
  evaluaciones          EvaluacionPsicologica[]
  traslados             Traslado[]
  pagos                 PagoChofer[]
}

// Contactos de emergencia del chofer (minimo 2 requeridos).
model ContactoEmergencia {
  @@map("contactos_emergencia")
  id          Int    @id @default(autoincrement())
  chofer_id   Int
  nombre      String
  telefono    String
  parentesco  String

  chofer Chofer @relation(fields: [chofer_id], references: [id])
}

// Vehiculo registrado por un chofer.
// activo=false hasta que pase la revision tecnica (calificacion >= 65).
model Vehiculo {
  @@map("vehiculos")
  id              Int      @id @default(autoincrement())
  chofer_id       Int
  placa           String   @unique
  marca           String
  modelo          String
  anio            Int
  color           String
  activo          Boolean  @default(true)
  creado_en       DateTime @default(now())

  chofer            Chofer              @relation(fields: [chofer_id], references: [id])
  revisiones        RevisionVehicular[]
}

// Evaluacion psicologica del chofer. Realizada por personal administrativo.
// La nota minima aprobatoria es 73. Si aprueba, el chofer se activa.
model EvaluacionPsicologica {
  @@map("evaluaciones_psicologicas")
  id              Int      @id @default(autoincrement())
  chofer_id       Int
  nota            Int
  fecha           DateTime
  aprobado        Boolean
  evaluador_id    Int
  creado_en       DateTime @default(now())

  chofer    Chofer        @relation(fields: [chofer_id], references: [id])
  evaluador PersonalAdmin @relation(fields: [evaluador_id], references: [id])
}

// Revision tecnica del vehiculo. Realizada por personal administrativo.
// Calificacion minima para apto es 65. Si es apto, el vehiculo se activa.
model RevisionVehicular {
  @@map("revisiones_vehiculares")
  id              Int      @id @default(autoincrement())
  vehiculo_id     Int
  calificacion    Int
  apto            Boolean
  fecha           DateTime
  evaluador_id    Int
  creado_en       DateTime @default(now())

  vehiculo  Vehiculo      @relation(fields: [vehiculo_id], references: [id])
  evaluador PersonalAdmin @relation(fields: [evaluador_id], references: [id])
}

// Cliente del sistema. Almacena el saldo disponible para pagar traslados.
model Cliente {
  @@map("clientes")
  id          Int      @id @default(autoincrement())
  usuario_id  Int      @unique
  saldo       Float    @default(0)
  creado_en   DateTime @default(now())

  usuario     Usuario       @relation(fields: [usuario_id], references: [id])
  recargas    RecargaSaldo[]
  traslados   Traslado[]
}

// Recarga de saldo realizada por un cliente.
// Registra banco, monto y numero de referencia de la transferencia.
model RecargaSaldo {
  @@map("recargas_saldo")
  id              Int      @id @default(autoincrement())
  cliente_id      Int
  monto           Float
  banco_id        Int
  nro_referencia  String
  fecha           DateTime @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id])
  banco   Banco   @relation(fields: [banco_id], references: [id])
}

// Traslado solicitado por un cliente y asignado a un chofer.
// estado: pendiente | completado | cancelado
// El costo total se divide: 30% empresa, 70% chofer.
// pagado indica si el chofer ya recibio el pago de este traslado.
model Traslado {
  @@map("traslados")
  id          Int      @id @default(autoincrement())
  cliente_id  Int
  chofer_id   Int
  origen      String
  destino     String
  costo       Float
  estado      String   @default("pendiente")
  fecha       DateTime @default(now())
  pagado      Boolean  @default(false)
  creado_en   DateTime @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id])
  chofer  Chofer  @relation(fields: [chofer_id], references: [id])
}

// Pago realizado por personal administrativo a un chofer.
// Reduce saldo_pendiente y aumenta saldo_pagado del chofer.
model PagoChofer {
  @@map("pagos_chofer")
  id              Int      @id @default(autoincrement())
  chofer_id       Int
  monto           Float
  fecha           DateTime @default(now())
  nro_referencia  String
  creado_en       DateTime @default(now())

  chofer Chofer @relation(fields: [chofer_id], references: [id])
}

// Catalogo de entidades bancarias.
model Banco {
  @@map("bancos")
  id    Int    @id @default(autoincrement())
  nombre String @unique

  choferes  Chofer[]
  recargas  RecargaSaldo[]
}

// Personal administrativo que gestiona evaluaciones, revisiones y pagos.
model PersonalAdmin {
  @@map("personal_admin")
  id          Int      @id @default(autoincrement())
  usuario_id  Int      @unique
  creado_en   DateTime @default(now())

  usuario               Usuario                @relation(fields: [usuario_id], references: [id])
  evaluaciones_psico    EvaluacionPsicologica[]
  revisiones_vehiculares RevisionVehicular[]
}
